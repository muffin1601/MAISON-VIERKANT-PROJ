// Maison Vierkant India — Prisma schema (planning draft; finalized in Phase 1)
// Datasource: Supabase Postgres. Generator: prisma-client-js.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")        // pooled (pgbouncer)
  directUrl = env("DIRECT_URL")          // migrations
}

// ---------- AUTH / RBAC ----------
model User {
  id            String     @id @default(cuid())
  email         String     @unique
  name          String?
  passwordHash  String?
  image         String?
  roleId        String
  role          Role       @relation(fields: [roleId], references: [id])
  isActive      Boolean    @default(true)
  lastLoginAt   DateTime?
  auditLogs     AuditLog[]
  customer      Customer?  // CRM record for storefront customers (role CUSTOMER)
  resetTokens   PasswordResetToken[]
  reviewedPayments PaymentSubmission[] @relation("ReviewedPayments")
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

/** One-time, hashed password-reset tokens (email-based; no SMS). */
model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique // sha256 of the token sent by email
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  @@index([userId])
}

model Role {
  id          String           @id @default(cuid())
  key         String           @unique // SUPER_ADMIN, ADMIN, SALES_MANAGER, SALES_EXECUTIVE, INVENTORY_MANAGER, CUSTOMER
  label       String
  users       User[]
  permissions RolePermission[]
}

model Permission {
  id    String           @id @default(cuid())
  key   String           @unique // e.g. products.write, orders.read, pricing.manage
  roles RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  @@id([roleId, permissionId])
}

// ---------- CATALOGUE ----------
model Category {
  id       String    @id @default(cuid())
  key      String    @unique // series group
  name     String
  products Product[]
}

model Collection {
  id       String              @id @default(cuid())
  slug     String              @unique
  name     String
  products ProductCollection[]
}

model Product {
  id          String              @id @default(cuid())
  code        String              @unique // e.g. AU_Series
  slug        String              @unique
  name        String
  description String?
  dimsSummary String?
  eurPrice    Decimal             @db.Decimal(10, 2)
  status      String              @default("ACTIVE") // ACTIVE | DRAFT | ARCHIVED
  featured    Boolean             @default(false)
  seoTitle    String?
  seoDescription String?
  categoryId  String?
  category    Category?           @relation(fields: [categoryId], references: [id])
  variants    ProductVariant[]
  images      ProductImage[]
  documents   ProductDocument[]
  finishes    ProductFinish[]
  collections ProductCollection[]
  inventory   Inventory?
  orderItems  OrderItem[]
  quoteItems  QuoteItem[]
  overrides   PriceOverride[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model ProductCollection {
  productId    String
  collectionId String
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  @@id([productId, collectionId])
}

model ProductVariant {
  id         String      @id @default(cuid())
  productId  String
  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  code       String      @unique // model code e.g. AU80
  eurPrice   Decimal     @db.Decimal(10, 2)
  dims       String?
  weightKg   Int?
  volumeL    Int?
  inventory  Inventory[]
  orderItems OrderItem[]
  @@index([productId])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  type      String  @default("GALLERY") // HERO | GALLERY | DRAWING
  sort      Int     @default(0)
}

/** Product attachments stored in Supabase Storage: PDFs, brochures, catalogues, CAD, sheets. */
model ProductDocument {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  kind       String   @default("DOCUMENT") // DOCUMENT | BROCHURE | CATALOGUE | TECH_SHEET | CAD | DRAWING
  url        String
  storageKey String? // object path within the bucket, for deletion
  bucket     String?
  filename   String
  mimeType   String?
  sizeBytes  Int?
  sort       Int      @default(0)
  uploaderId String?
  createdAt  DateTime @default(now())
  @@index([productId])
}

model Finish {
  id       String          @id @default(cuid())
  name     String          @unique
  products ProductFinish[]
}

model ProductFinish {
  productId String
  finishId  String
  tier      String  @default("STD") // BASIC | STD | ENGOBE
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  finish    Finish  @relation(fields: [finishId], references: [id], onDelete: Cascade)
  @@id([productId, finishId])
}

model Project {
  id        String   @id @default(cuid())
  name      String
  location  String
  summary   String
  imageUrl  String
  sort      Int      @default(0)
  createdAt DateTime @default(now())
}

// ---------- INVENTORY ----------
model Inventory {
  id                String                 @id @default(cuid())
  productId         String?                @unique
  variantId         String?
  product           Product?               @relation(fields: [productId], references: [id])
  variant           ProductVariant?        @relation(fields: [variantId], references: [id])
  warehouse         String                 @default("MAIN")
  quantity          Int                    @default(0)
  lowStockThreshold Int                    @default(2)
  transactions      InventoryTransaction[]
}

model InventoryTransaction {
  id           String    @id @default(cuid())
  inventoryId  String
  inventory    Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  delta        Int
  reason       String // PURCHASE | SALE | ADJUSTMENT | RETURN
  balanceAfter Int
  actorId      String?
  note         String?
  createdAt    DateTime  @default(now())
}

// ---------- CRM ----------
model Customer {
  id        String         @id @default(cuid())
  name      String
  email     String?
  phone     String?
  company   String?
  leadId    String?        @unique
  lead      Lead?          @relation(fields: [leadId], references: [id])
  userId    String?        @unique // linked auth account (storefront login)
  user      User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  addresses Address[]
  orders    Order[]
  quotes    Quote[]
  notes     CustomerNote[]
  paymentSubmissions PaymentSubmission[]
  wishlist  WishlistItem[]
  supportTickets SupportTicket[]
  savedCards SavedCard[]
  razorpayCustomerId String? // Razorpay customer handle for the token vault
  createdAt  DateTime      @default(now())
}

/**
 * A tokenised card saved in the Razorpay vault. We store ONLY the non-sensitive
 * display fields + the Razorpay token handle — never a PAN/CVV. PCI scope stays
 * entirely with Razorpay.
 */
model SavedCard {
  id                 String   @id @default(cuid())
  customerId         String
  customer           Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  razorpayTokenId    String   @unique // token_xxx
  razorpayCustomerId String // cust_xxx that owns the token
  network            String? // Visa | MasterCard | RuPay | Amex …
  last4              String?
  issuer             String?
  expiryMonth        Int?
  expiryYear         Int?
  isDefault          Boolean  @default(false)
  createdAt          DateTime @default(now())
  @@index([customerId])
}

/**
 * Customer support / return / refund request. One table, discriminated by `type`.
 * Created from the public support center or a logged-in customer's order page.
 */
model SupportTicket {
  id          String    @id @default(cuid())
  type        String    @default("SUPPORT") // SUPPORT | RETURN | REFUND | ORDER
  status      String    @default("OPEN") // OPEN | IN_PROGRESS | RESOLVED | CLOSED
  orderNumber String?
  customerId  String?
  customer    Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  name        String
  email       String
  phone       String?
  subject     String
  message     String
  adminNote   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  @@index([status])
  @@index([type])
  @@index([customerId])
}

/** DB-backed wishlist entry (one row per saved product), keyed by product slug for cross-device sync. */
model WishlistItem {
  id          String   @id @default(cuid())
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  productSlug String
  createdAt   DateTime @default(now())
  @@unique([customerId, productSlug])
  @@index([customerId])
}

model Address {
  id         String     @id @default(cuid())
  customerId String
  customer   Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  type       String     @default("SHIPPING") // BILLING | SHIPPING
  label      String? // "Home", "Studio" — customer-facing nickname
  name       String? // recipient name
  phone      String? // recipient phone (10-digit, India)
  company    String?
  gstin      String?
  line1      String
  line2      String?
  city       String
  state      String
  pincode    String
  country    String     @default("India")
  isDefault  Boolean    @default(false)
  orders     Order[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @default(now()) @updatedAt
  @@index([customerId])
}

model CustomerNote {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  body       String
  authorId   String?
  createdAt  DateTime @default(now())
}

// ---------- ORDERS ----------
model Order {
  id             String      @id @default(cuid())
  number         String      @unique // MVI-ORD-xxxxxx
  customerId     String
  customer       Customer    @relation(fields: [customerId], references: [id])
  shipAddressId  String?
  shipAddress    Address?    @relation(fields: [shipAddressId], references: [id])
  status         String      @default("PENDING")
  subtotalInr    Decimal     @db.Decimal(12, 2)
  transportInr   Decimal     @default(0) @db.Decimal(12, 2)
  gstInr         Decimal     @default(0) @db.Decimal(12, 2)
  discountInr    Decimal     @default(0) @db.Decimal(12, 2)
  couponCode     String?
  totalInr       Decimal     @db.Decimal(12, 2)
  advanceInr     Decimal     @db.Decimal(12, 2)
  trackingNumber String?
  courier        String? // courier/logistics partner name (e.g. "Delhivery")
  trackingUrl    String? // direct tracking link for the shipment
  items          OrderItem[]
  invoice        Invoice?
  payments       Payment[]
  paymentSubmissions PaymentSubmission[]
  statusHistory  OrderStatusEvent[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

/** Append-only audit of an order's status changes — powers the customer-facing timeline. */
model OrderStatusEvent {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status    String // internal status key (see lib/orderStatus)
  note      String?
  actorId   String? // admin user id, if changed from the console
  createdAt DateTime @default(now())
  @@index([orderId])
}

/**
 * Customer-submitted proof of an OFFLINE payment (bank transfer / UPI / NEFT / RTGS /
 * wire). Reviewed and approved/rejected by an admin. The proof file lives in a PRIVATE
 * Supabase bucket; only the owning customer and authorized admins can fetch a signed URL.
 */
model PaymentSubmission {
  id              String    @id @default(cuid())
  orderId         String
  order           Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customerId      String?
  customer        Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  method          String    // BANK_TRANSFER | UPI | NEFT | RTGS | WIRE
  transactionId   String    // bank/UPI reference number entered by the customer
  amountInr       Decimal   @db.Decimal(12, 2)
  paidAt          DateTime  // date the customer made the payment
  notes           String?
  proofUrl        String?   // public URL (only set if a public bucket is used)
  proofBucket     String?
  proofKey        String?   // object path in the private bucket — fetched via signed URL
  proofMime       String?
  proofSizeBytes  Int?
  status          String    @default("SUBMITTED") // SUBMITTED | VERIFIED | REJECTED
  rejectionReason String?
  reviewedById    String?
  reviewedBy      User?     @relation("ReviewedPayments", fields: [reviewedById], references: [id])
  reviewedAt      DateTime?
  submitterIp     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  @@index([orderId])
  @@index([customerId])
  @@index([status])
}

model OrderItem {
  id          String          @id @default(cuid())
  orderId     String
  order       Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  product     Product         @relation(fields: [productId], references: [id])
  variantId   String?
  variant     ProductVariant? @relation(fields: [variantId], references: [id])
  finish      String
  qty         Int
  eurAtOrder  Decimal         @db.Decimal(10, 2)
  unitPriceInr Decimal        @db.Decimal(12, 2)
  pricingSnapshot Json
}

model Invoice {
  id        String   @id @default(cuid())
  orderId   String   @unique
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  number    String   @unique
  pdfUrl    String?
  createdAt DateTime @default(now())
}

model Payment {
  id               String   @id @default(cuid())
  orderId          String
  order            Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  provider         String   @default("MOCK") // MOCK | RAZORPAY | COD
  method           String? // upi | card | netbanking | cod | etc. (from gateway)
  type             String   @default("ADVANCE") // ADVANCE | BALANCE | FULL
  status           String   @default("PENDING") // PENDING | PROCESSING | CAPTURED | FAILED | REFUNDED
  amountInr        Decimal  @db.Decimal(12, 2)
  amountRefundedInr Decimal @default(0) @db.Decimal(12, 2) // cumulative refunded amount (partial refunds)
  currency         String   @default("INR") // ISO currency of amountInr
  reference        String? // free-form human reference / gateway receipt id
  gatewayOrderId   String?  @unique // e.g. Razorpay order_xxx
  gatewayPaymentId String?  @unique // e.g. Razorpay pay_xxx — also the capture idempotency key
  signature        String? // gateway signature (audit trail)
  webhookVerified  Boolean  @default(false) // true once a webhook confirmed the capture/refund server-side
  paidAt           DateTime? // when the gateway captured the payment
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  @@index([orderId])
  @@index([status])
}

/**
 * Ephemeral checkout draft. Holds the cart + customer + SERVER-COMPUTED money
 * snapshot before any permanent Order exists. The real Order is created only on
 * (a) verified Razorpay payment, or (b) a bank-transfer "Place Order" click — so
 * abandoned/unpaid online attempts never pollute the Order table. Expires in 24h;
 * a pg_cron job + lazy read-time checks purge stale rows.
 */
model CheckoutSession {
  id             String    @id @default(cuid())
  token          String    @unique // high-entropy public handle used by the browser
  status         String    @default("DRAFT") // DRAFT | PAYMENT_PROCESSING | COMPLETED | FAILED | EXPIRED
  orderNumber    String    @unique // pre-allocated MVI-ORD-… reused when the Order is created
  paymentMethod  String? // RAZORPAY | BANK_TRANSFER
  customerJson   Json // { name,email,phone,company,gst, billing{…}, shipping{…} }
  itemsJson      Json // [{ code, variantCode, finish, qty }]
  subtotalInr    Decimal   @db.Decimal(12, 2) // ex-GST
  gstInr         Decimal   @default(0) @db.Decimal(12, 2)
  shippingInr    Decimal   @default(0) @db.Decimal(12, 2)
  discountInr    Decimal   @default(0) @db.Decimal(12, 2)
  couponCode     String?
  totalInr       Decimal   @db.Decimal(12, 2)
  advanceInr     Decimal   @db.Decimal(12, 2)
  gatewayOrderId String?   @unique // Razorpay order id created against this session
  customerUserId String? // linked storefront account, if logged in
  orderId        String?   @unique // the real Order, once created (idempotency anchor)
  expiresAt      DateTime
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  @@index([status])
  @@index([expiresAt])
}

// ---------- QUOTES (B2B) ----------
model Quote {
  id             String         @id @default(cuid())
  number         String         @unique // MVI-QT-xxxxxx
  customerId     String?
  customer       Customer?      @relation(fields: [customerId], references: [id])
  status         String         @default("DRAFT")
  dealerMarkupPct Decimal       @default(0) @db.Decimal(5, 2)
  billingJson    Json?
  deliveryJson   Json?
  subtotalInr    Decimal        @db.Decimal(12, 2)
  totalInr       Decimal        @db.Decimal(12, 2)
  pdfUrl         String?
  items          QuoteItem[]
  versions       QuoteVersion[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model QuoteItem {
  id          String  @id @default(cuid())
  quoteId     String
  quote       Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  productId   String
  product     Product @relation(fields: [productId], references: [id])
  variantCode String?
  finish      String
  qty         Int
  unitPriceInr Decimal @db.Decimal(12, 2)
}

model QuoteVersion {
  id        String   @id @default(cuid())
  quoteId   String
  quote     Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  version   Int
  snapshot  Json
  createdAt DateTime @default(now())
}

// ---------- LEADS ----------
model Lead {
  id        String     @id @default(cuid())
  source    String     @default("CATALOGUE") // CATALOGUE | CONTACT | TRADE
  name      String
  email     String?
  phone     String?
  company   String?
  type      String?
  status    String     @default("NEW") // NEW | CONTACTED | QUALIFIED | WON | LOST
  notes     LeadNote[]
  customer  Customer?
  createdAt DateTime   @default(now())
}

model LeadNote {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  body      String
  authorId  String?
  createdAt DateTime @default(now())
}

// ---------- PURCHASE ORDERS (to supplier) ----------
model PurchaseOrder {
  id        String              @id @default(cuid())
  number    String              @unique // MVI-PO-xxxxxx
  supplier  String              @default("Atelier Vierkant")
  currency  String              @default("EUR")
  status    String              @default("DRAFT")
  totalEur  Decimal             @db.Decimal(12, 2)
  items     PurchaseOrderItem[]
  createdAt DateTime            @default(now())
}

model PurchaseOrderItem {
  id        String        @id @default(cuid())
  poId      String
  po        PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  variantCode String
  qty       Int
  unitEur   Decimal       @db.Decimal(10, 2)
}

// ---------- COUPONS ----------
model Coupon {
  id             String             @id @default(cuid())
  code           String             @unique // stored uppercase
  description    String?
  type           String             @default("PERCENT") // PERCENT | FLAT
  value          Decimal            @db.Decimal(10, 2) // percent (0-100) or flat INR
  minSubtotalInr Decimal            @default(0) @db.Decimal(12, 2)
  maxDiscountInr Decimal?           @db.Decimal(12, 2) // cap for percent coupons
  usageLimit     Int? // total redemptions allowed (null = unlimited)
  perUserLimit   Int                @default(1) // redemptions per customer (0 = unlimited)
  usedCount      Int                @default(0)
  startsAt       DateTime?
  expiresAt      DateTime?
  isActive       Boolean            @default(true)
  isPublic       Boolean            @default(true) // listed in the customer's "available coupons"
  redemptions    CouponRedemption[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  @@index([isActive])
}

model CouponRedemption {
  id          String   @id @default(cuid())
  couponId    String
  coupon      Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  customerId  String?
  orderNumber String?
  amountInr   Decimal  @db.Decimal(12, 2)
  createdAt   DateTime @default(now())
  @@index([couponId])
  @@index([customerId])
}

// ---------- PRICING ----------
model PricingRule {
  id            String          @id @default(cuid())
  name          String          @default("Default")
  rate          Decimal         @db.Decimal(8, 4) // FX EUR->INR
  discountPct   Decimal         @default(0) @db.Decimal(5, 2)
  transportPct  Decimal         @default(18) @db.Decimal(5, 2)
  packingFlat   Decimal         @default(1500) @db.Decimal(10, 2)
  dutyPct       Decimal         @default(25) @db.Decimal(5, 2)
  swsPct        Decimal         @default(0) @db.Decimal(5, 2) // Social Welfare Surcharge (% of duty)
  gstPct        Decimal         @default(18) @db.Decimal(5, 2)
  profitPct     Decimal         @default(25) @db.Decimal(5, 2)
  dealerMarkupPct Decimal       @default(0) @db.Decimal(5, 2)
  formulaKey    String          @default("STANDARD")
  isActive      Boolean         @default(true)
  overrides     PriceOverride[]
  createdAt     DateTime        @default(now())
}

model PriceOverride {
  id           String       @id @default(cuid())
  productId    String
  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  pricingRuleId String?
  pricingRule  PricingRule? @relation(fields: [pricingRuleId], references: [id])
  sourceFileId String?
  sourceFile   UploadedFile? @relation(fields: [sourceFileId], references: [id])
  eurPrice     Decimal      @db.Decimal(10, 2)
  createdAt    DateTime     @default(now())
}

model UploadedFile {
  id          String          @id @default(cuid())
  kind        String // PRICE_LIST | PRODUCT_SHEET | MEDIA | DRAWING | DOCUMENT
  url         String
  storageKey  String?
  bucket      String?
  filename    String
  mimeType    String?
  sizeBytes   Int?
  parseStatus String          @default("PENDING")
  parsedJson  Json?
  uploaderId  String?
  overrides   PriceOverride[]
  createdAt   DateTime        @default(now())
}

// ---------- SYSTEM ----------
model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value Json
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  actor     User?    @relation(fields: [actorId], references: [id])
  action    String
  entity    String
  entityId  String?
  before    Json?
  after     Json?
  ip        String?
  createdAt DateTime @default(now())
  @@index([entity, entityId])
}
