// Maison Vierkant India — Prisma schema (planning draft; finalized in Phase 1)
// Datasource: Supabase Postgres. Generator: prisma-client-js.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")        // pooled (pgbouncer)
  directUrl = env("DIRECT_URL")          // migrations
}

// ---------- AUTH / RBAC ----------
model User {
  id            String     @id @default(cuid())
  email         String     @unique
  name          String?
  passwordHash  String?
  image         String?
  roleId        String
  role          Role       @relation(fields: [roleId], references: [id])
  isActive      Boolean    @default(true)
  lastLoginAt   DateTime?
  auditLogs     AuditLog[]
  customer      Customer?  // CRM record for storefront customers (role CUSTOMER)
  resetTokens   PasswordResetToken[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

/** One-time, hashed password-reset tokens (email-based; no SMS). */
model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique // sha256 of the token sent by email
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  @@index([userId])
}

model Role {
  id          String           @id @default(cuid())
  key         String           @unique // SUPER_ADMIN, ADMIN, SALES_MANAGER, SALES_EXECUTIVE, INVENTORY_MANAGER, CUSTOMER
  label       String
  users       User[]
  permissions RolePermission[]
}

model Permission {
  id    String           @id @default(cuid())
  key   String           @unique // e.g. products.write, orders.read, pricing.manage
  roles RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  @@id([roleId, permissionId])
}

// ---------- CATALOGUE ----------
model Category {
  id       String    @id @default(cuid())
  key      String    @unique // series group
  name     String
  products Product[]
}

model Collection {
  id       String              @id @default(cuid())
  slug     String              @unique
  name     String
  products ProductCollection[]
}

model Product {
  id          String              @id @default(cuid())
  code        String              @unique // e.g. AU_Series
  slug        String              @unique
  name        String
  description String?
  dimsSummary String?
  eurPrice    Decimal             @db.Decimal(10, 2)
  status      String              @default("ACTIVE") // ACTIVE | DRAFT | ARCHIVED
  featured    Boolean             @default(false)
  seoTitle    String?
  seoDescription String?
  categoryId  String?
  category    Category?           @relation(fields: [categoryId], references: [id])
  variants    ProductVariant[]
  images      ProductImage[]
  documents   ProductDocument[]
  finishes    ProductFinish[]
  collections ProductCollection[]
  inventory   Inventory?
  orderItems  OrderItem[]
  quoteItems  QuoteItem[]
  overrides   PriceOverride[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model ProductCollection {
  productId    String
  collectionId String
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  @@id([productId, collectionId])
}

model ProductVariant {
  id         String      @id @default(cuid())
  productId  String
  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  code       String      @unique // model code e.g. AU80
  eurPrice   Decimal     @db.Decimal(10, 2)
  dims       String?
  weightKg   Int?
  volumeL    Int?
  inventory  Inventory[]
  orderItems OrderItem[]
  @@index([productId])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  type      String  @default("GALLERY") // HERO | GALLERY | DRAWING
  sort      Int     @default(0)
}

/** Product attachments stored in Supabase Storage: PDFs, brochures, catalogues, CAD, sheets. */
model ProductDocument {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  kind       String   @default("DOCUMENT") // DOCUMENT | BROCHURE | CATALOGUE | TECH_SHEET | CAD | DRAWING
  url        String
  storageKey String? // object path within the bucket, for deletion
  bucket     String?
  filename   String
  mimeType   String?
  sizeBytes  Int?
  sort       Int      @default(0)
  uploaderId String?
  createdAt  DateTime @default(now())
  @@index([productId])
}

model Finish {
  id       String          @id @default(cuid())
  name     String          @unique
  products ProductFinish[]
}

model ProductFinish {
  productId String
  finishId  String
  tier      String  @default("STD") // BASIC | STD | ENGOBE
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  finish    Finish  @relation(fields: [finishId], references: [id], onDelete: Cascade)
  @@id([productId, finishId])
}

model Project {
  id        String   @id @default(cuid())
  name      String
  location  String
  summary   String
  imageUrl  String
  sort      Int      @default(0)
  createdAt DateTime @default(now())
}

// ---------- INVENTORY ----------
model Inventory {
  id                String                 @id @default(cuid())
  productId         String?                @unique
  variantId         String?
  product           Product?               @relation(fields: [productId], references: [id])
  variant           ProductVariant?        @relation(fields: [variantId], references: [id])
  warehouse         String                 @default("MAIN")
  quantity          Int                    @default(0)
  lowStockThreshold Int                    @default(2)
  transactions      InventoryTransaction[]
}

model InventoryTransaction {
  id           String    @id @default(cuid())
  inventoryId  String
  inventory    Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  delta        Int
  reason       String // PURCHASE | SALE | ADJUSTMENT | RETURN
  balanceAfter Int
  actorId      String?
  note         String?
  createdAt    DateTime  @default(now())
}

// ---------- CRM ----------
model Customer {
  id        String         @id @default(cuid())
  name      String
  email     String?
  phone     String?
  company   String?
  leadId    String?        @unique
  lead      Lead?          @relation(fields: [leadId], references: [id])
  userId    String?        @unique // linked auth account (storefront login)
  user      User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  addresses Address[]
  orders    Order[]
  quotes    Quote[]
  notes     CustomerNote[]
  createdAt  DateTime      @default(now())
}

model Address {
  id         String     @id @default(cuid())
  customerId String
  customer   Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  type       String     @default("SHIPPING") // BILLING | SHIPPING
  line1      String
  line2      String?
  city       String
  state      String
  pincode    String
  country    String     @default("India")
  orders     Order[]
}

model CustomerNote {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  body       String
  authorId   String?
  createdAt  DateTime @default(now())
}

// ---------- ORDERS ----------
model Order {
  id             String      @id @default(cuid())
  number         String      @unique // MVI-ORD-xxxxxx
  customerId     String
  customer       Customer    @relation(fields: [customerId], references: [id])
  shipAddressId  String?
  shipAddress    Address?    @relation(fields: [shipAddressId], references: [id])
  status         String      @default("PENDING")
  subtotalInr    Decimal     @db.Decimal(12, 2)
  transportInr   Decimal     @default(0) @db.Decimal(12, 2)
  gstInr         Decimal     @default(0) @db.Decimal(12, 2)
  totalInr       Decimal     @db.Decimal(12, 2)
  advanceInr     Decimal     @db.Decimal(12, 2)
  trackingNumber String?
  items          OrderItem[]
  invoice        Invoice?
  payments       Payment[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model OrderItem {
  id          String          @id @default(cuid())
  orderId     String
  order       Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  product     Product         @relation(fields: [productId], references: [id])
  variantId   String?
  variant     ProductVariant? @relation(fields: [variantId], references: [id])
  finish      String
  qty         Int
  eurAtOrder  Decimal         @db.Decimal(10, 2)
  unitPriceInr Decimal        @db.Decimal(12, 2)
  pricingSnapshot Json
}

model Invoice {
  id        String   @id @default(cuid())
  orderId   String   @unique
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  number    String   @unique
  pdfUrl    String?
  createdAt DateTime @default(now())
}

model Payment {
  id               String   @id @default(cuid())
  orderId          String
  order            Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  provider         String   @default("MOCK") // MOCK | RAZORPAY | COD
  method           String? // upi | card | netbanking | cod | etc. (from gateway)
  type             String   @default("ADVANCE") // ADVANCE | BALANCE | FULL
  status           String   @default("PENDING") // PENDING | CAPTURED | FAILED | REFUNDED
  amountInr        Decimal  @db.Decimal(12, 2)
  reference        String? // free-form human reference
  gatewayOrderId   String?  @unique // e.g. Razorpay order_xxx
  gatewayPaymentId String?  @unique // e.g. Razorpay pay_xxx — also the capture idempotency key
  signature        String? // gateway signature (audit trail)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ---------- QUOTES (B2B) ----------
model Quote {
  id             String         @id @default(cuid())
  number         String         @unique // MVI-QT-xxxxxx
  customerId     String?
  customer       Customer?      @relation(fields: [customerId], references: [id])
  status         String         @default("DRAFT")
  dealerMarkupPct Decimal       @default(0) @db.Decimal(5, 2)
  billingJson    Json?
  deliveryJson   Json?
  subtotalInr    Decimal        @db.Decimal(12, 2)
  totalInr       Decimal        @db.Decimal(12, 2)
  pdfUrl         String?
  items          QuoteItem[]
  versions       QuoteVersion[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model QuoteItem {
  id          String  @id @default(cuid())
  quoteId     String
  quote       Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  productId   String
  product     Product @relation(fields: [productId], references: [id])
  variantCode String?
  finish      String
  qty         Int
  unitPriceInr Decimal @db.Decimal(12, 2)
}

model QuoteVersion {
  id        String   @id @default(cuid())
  quoteId   String
  quote     Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  version   Int
  snapshot  Json
  createdAt DateTime @default(now())
}

// ---------- LEADS ----------
model Lead {
  id        String     @id @default(cuid())
  source    String     @default("CATALOGUE") // CATALOGUE | CONTACT | TRADE
  name      String
  email     String?
  phone     String?
  company   String?
  type      String?
  status    String     @default("NEW") // NEW | CONTACTED | QUALIFIED | WON | LOST
  notes     LeadNote[]
  customer  Customer?
  createdAt DateTime   @default(now())
}

model LeadNote {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  body      String
  authorId  String?
  createdAt DateTime @default(now())
}

// ---------- PURCHASE ORDERS (to supplier) ----------
model PurchaseOrder {
  id        String              @id @default(cuid())
  number    String              @unique // MVI-PO-xxxxxx
  supplier  String              @default("Atelier Vierkant")
  currency  String              @default("EUR")
  status    String              @default("DRAFT")
  totalEur  Decimal             @db.Decimal(12, 2)
  items     PurchaseOrderItem[]
  createdAt DateTime            @default(now())
}

model PurchaseOrderItem {
  id        String        @id @default(cuid())
  poId      String
  po        PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  variantCode String
  qty       Int
  unitEur   Decimal       @db.Decimal(10, 2)
}

// ---------- PRICING ----------
model PricingRule {
  id            String          @id @default(cuid())
  name          String          @default("Default")
  rate          Decimal         @db.Decimal(8, 4) // FX EUR->INR
  discountPct   Decimal         @default(0) @db.Decimal(5, 2)
  transportPct  Decimal         @default(18) @db.Decimal(5, 2)
  packingFlat   Decimal         @default(1500) @db.Decimal(10, 2)
  dutyPct       Decimal         @default(25) @db.Decimal(5, 2)
  swsPct        Decimal         @default(0) @db.Decimal(5, 2) // Social Welfare Surcharge (% of duty)
  gstPct        Decimal         @default(18) @db.Decimal(5, 2)
  profitPct     Decimal         @default(25) @db.Decimal(5, 2)
  dealerMarkupPct Decimal       @default(0) @db.Decimal(5, 2)
  formulaKey    String          @default("STANDARD")
  isActive      Boolean         @default(true)
  overrides     PriceOverride[]
  createdAt     DateTime        @default(now())
}

model PriceOverride {
  id           String       @id @default(cuid())
  productId    String
  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  pricingRuleId String?
  pricingRule  PricingRule? @relation(fields: [pricingRuleId], references: [id])
  sourceFileId String?
  sourceFile   UploadedFile? @relation(fields: [sourceFileId], references: [id])
  eurPrice     Decimal      @db.Decimal(10, 2)
  createdAt    DateTime     @default(now())
}

model UploadedFile {
  id          String          @id @default(cuid())
  kind        String // PRICE_LIST | PRODUCT_SHEET | MEDIA | DRAWING | DOCUMENT
  url         String
  storageKey  String?
  bucket      String?
  filename    String
  mimeType    String?
  sizeBytes   Int?
  parseStatus String          @default("PENDING")
  parsedJson  Json?
  uploaderId  String?
  overrides   PriceOverride[]
  createdAt   DateTime        @default(now())
}

// ---------- SYSTEM ----------
model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value Json
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  actor     User?    @relation(fields: [actorId], references: [id])
  action    String
  entity    String
  entityId  String?
  before    Json?
  after     Json?
  ip        String?
  createdAt DateTime @default(now())
  @@index([entity, entityId])
}
