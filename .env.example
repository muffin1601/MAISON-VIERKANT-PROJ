# ---- Database (Supabase Postgres) ----
# Pooled connection (pgbouncer, port 6543) used by the app at runtime
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection (port 5432) used by Prisma Migrate
DIRECT_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# ---- Supabase (storage + optional auth) ----
# Service role is server-only (bypasses RLS). Never expose with NEXT_PUBLIC_.
NEXT_PUBLIC_SUPABASE_URL="https://<ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
# Buckets are created by supabase/storage-setup.sql:
#   products-images · product-documents · catalogues · drawings · uploads
# (legacy single bucket below is optional/back-compat)
SUPABASE_STORAGE_BUCKET="mvi-media"

# ---- Auth (NextAuth) ----
# Local dev: http://localhost:3000
# Production (Vercel): set to the full https deployment URL, e.g.
# https://maison-vierkant-proj.vercel.app
NEXTAUTH_URL="https://maison-vierkant-proj.vercel.app"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# ---- Payments ----
# mock     = checkout completes locally without a gateway (dev/preview only)
# razorpay = live Razorpay Checkout (requires the keys below)
PAYMENT_PROVIDER="mock"   # mock | razorpay
# Razorpay Dashboard → Settings → API Keys. rzp_test_* for test mode, rzp_live_* for production.
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
# Razorpay Dashboard → Settings → Webhooks. Add a webhook for `payment.captured`
# and `payment.failed` pointing at https://<your-domain>/api/webhooks/razorpay,
# then paste its signing secret here.
RAZORPAY_WEBHOOK_SECRET=""
# Cash on Delivery toggle for checkout.
COD_ENABLED="true"        # true | false

# ---- Email (Resend) — the ONLY notification channel. No SMS. ----
# Create a free key at https://resend.com (3,000 emails/mo free).
# When unset, emails are logged to the server console instead of being sent
# (so dev/preview still works end-to-end). Verify a domain to send from your own.
RESEND_API_KEY=""
EMAIL_FROM="Maison Vierkant <onboarding@resend.dev>"
# Where new-lead / new-order admin notifications are delivered.
ADMIN_NOTIFY_EMAIL="report@watcon.net"

# ---- App ----
# Public base URL used to build links inside emails (password reset, order view).
# Defaults to NEXTAUTH_URL, then http://localhost:3000.
APP_URL="https://maison-vierkant-proj.vercel.app"
NODE_ENV="development"
